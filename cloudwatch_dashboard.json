      "width": 12,
      "height": 6,
      "x": 12,
      "y": 6
    },
    {
      "type": "metric",
      "properties": {
        "metrics": [
          [ "AWS/Lambda", "Errors", { "stat": "Sum", "label": "Advisor Errors", "color": "#d62728" } ],
          [ "...", { "stat": "Sum", "label": "Profile Errors", "color": "#ff7f0e" } ]
        ],
        "view": "timeSeries",
        "stacked": false,
        "region": "us-east-1",
        "title": "Error Count",
        "period": 300,
        "yAxis": {
          "left": {
            "min": 0
          }
